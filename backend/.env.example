# Shared Turso (libSQL) database. Copy to .env and fill the token (shared by
# the team out of band). The URL is the database host WITHOUT the /v2/pipeline
# suffix; the code appends it.
TURSO_DATABASE_URL=https://your-db-name.region.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Downstream service URLs used by the Search API gateway
POKE_API_URL=http://localhost:8001
POKE_STATS_URL=http://localhost:8002
POKE_IMAGES_URL=http://localhost:8003

# Per-request timeout (seconds) for downstream calls
DOWNSTREAM_TIMEOUT=5
